<?xml version='1.0' encoding='windows-1252'?>

<?if $(sys.BUILDARCH) = x64 or $(sys.BUILDARCH) = arm64 ?>
    <?define PlatformProgramFilesFolder = "ProgramFiles64Folder" ?>
<?else ?>
    <?define PlatformProgramFilesFolder = "ProgramFilesFolder" ?>
<?endif ?>

<Wix xmlns='http://schemas.microsoft.com/wix/2006/wi'>

    <Product
        Id='*'
        Name='ComfyUI MCP Server'
        UpgradeCode='B7E3F1A2-8C4D-4F6E-9A1B-3D5E7F2C8A4B'
        Manufacturer='septagramm'
        Language='1033'
        Codepage='1252'
        Version='$(var.Version)'>

        <Package Id='*'
            Keywords='Installer'
            Description='MCP server for ComfyUI image generation in Claude Code'
            Manufacturer='septagramm'
            InstallerVersion='450'
            Languages='1033'
            Compressed='yes'
            InstallScope='perMachine'
            SummaryCodepage='1252'/>

        <MajorUpgrade
            Schedule='afterInstallInitialize'
            DowngradeErrorMessage='A newer version of [ProductName] is already installed. Setup will now exit.'/>

        <Media Id='1' Cabinet='media1.cab' EmbedCab='yes' CompressionLevel='high'/>

        <Directory Id='TARGETDIR' Name='SourceDir'>
            <Directory Id='$(var.PlatformProgramFilesFolder)' Name='PFiles'>
                <Directory Id='APPLICATIONFOLDER' Name='ComfyUI MCP'>

                    <!-- Main executable -->
                    <Component Id='MainExe' Guid='*'>
                        <File
                            Id='exe0'
                            Name='comfy-ui-mcp.exe'
                            DiskId='1'
                            Source='$(var.CargoTargetBinDir)\comfy-ui-mcp.exe'
                            KeyPath='yes'/>
                    </Component>

                    <!-- Add install dir to system PATH -->
                    <Component Id='PathEntry' Guid='A1C2E3F4-5B6D-7E8F-9A0B-1C2D3E4F5A6B'>
                        <CreateFolder/>
                        <Environment
                            Id='PATH'
                            Name='PATH'
                            Value='[APPLICATIONFOLDER]'
                            Permanent='no'
                            Part='last'
                            Action='set'
                            System='yes'/>
                    </Component>

                </Directory>
            </Directory>
        </Directory>

        <!-- Custom actions: register/unregister MCP in Claude Code -->
        <CustomAction
            Id='RegisterMcp'
            FileKey='exe0'
            ExeCommand='--register'
            Execute='deferred'
            Impersonate='yes'
            Return='check'/>

        <CustomAction
            Id='UnregisterMcp'
            FileKey='exe0'
            ExeCommand='--unregister'
            Execute='deferred'
            Impersonate='yes'
            Return='ignore'/>

        <InstallExecuteSequence>
            <Custom Action='RegisterMcp' After='InstallFiles'>
                NOT Installed AND NOT REMOVE
            </Custom>
            <Custom Action='UnregisterMcp' Before='RemoveFiles'>
                REMOVE="ALL"
            </Custom>
        </InstallExecuteSequence>

        <Feature
            Id='Binaries'
            Title='Application'
            Description='Installs ComfyUI MCP Server and adds it to PATH.'
            Level='1'
            ConfigurableDirectory='APPLICATIONFOLDER'
            AllowAdvertise='no'
            Absent='disallow'>
            <ComponentRef Id='MainExe'/>
            <ComponentRef Id='PathEntry'/>
        </Feature>

        <SetProperty Id='ARPINSTALLLOCATION' Value='[APPLICATIONFOLDER]' After='CostFinalize'/>

        <UI>
            <UIRef Id='WixUI_Minimal'/>
        </UI>

    </Product>

</Wix>
